<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Inventory</title>
    <style>
      table{
        text-align: center;
        border-collapse: collapse;
        border: 3px solid black;
      }
      th,td{
        padding: 7px;
      }
    </style>
</head>
<body>
    <center><h1>Items</h1>
    <table border="1">
        <tr style="border: 3px solid black;">
          <th>ID</th>
          <th>Item</th>
          <th>Quantity</th>
          <th>Price</th>
          <th>Description</th>
        </tr>
        <% inventory.forEach(items => { %>
        <tr>
          <td><%= items.id %></td>
          <td><%= items.Item %></td>
          <td><%= items.Quantity %></td>
          <td><%= items.Price %></td>
          <td><%= items.Description %></td>
        </tr>
        <% }); %>
      </table></center> 
</body>
</html>